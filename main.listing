wire alarm_match =
    alarm_valid &&          // 已经设置过闹钟
    !alarm_sw &&            // 现在不在闹钟设置界面
    !time_set_mode &&       // 现在也不在普通校时界面
    cur_sec_0  == alarm_sec_0  &&
    cur_sec_1  == alarm_sec_1  &&
    cur_min_0  == alarm_min_0  &&
    cur_min_1  == alarm_min_1  &&
    cur_hour_0 == alarm_hour_0 &&
    cur_hour_1 == alarm_hour_1;
